.task

# Vite output is generated by the build. We keep the directory (via a tracked
# placeholder) so `go:embed all:dist` in frontend/embed.go always compiles,
# even on a fresh checkout before the frontend has been built.
frontend/dist/*
!frontend/dist/.gitkeep

frontend/node_modules
build/linux/appimage/build
build/windows/nsis/MicrosoftEdgeWebview2Setup.exe
